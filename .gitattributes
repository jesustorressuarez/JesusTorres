# Normalizar finales de línea: LF en el repo, nativo en working dir
* text=auto eol=lf

# Forzar LF en archivos de texto
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.svg  text eol=lf
*.xml  text eol=lf
*.txt  text eol=lf

# Binarios — no tocar
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.avif binary
*.ico  binary
*.mp3  binary
*.wav  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
